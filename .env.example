NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=
# Optional: comma- or space-separated origins allowed to present Clerk session tokens.
# Set in production to the public app origin, for example:
# CLERK_AUTHORIZED_PARTIES=https://events.ineedtofeedmyrabbit.com
CLERK_AUTHORIZED_PARTIES=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
# Optional local-only deploy secret for Convex preview deployments.
CONVEX_PREVIEW_DEPLOY_KEY=
# Optional self-hosted Convex settings for local/VPS testing. Browser-facing
# NEXT_PUBLIC_CONVEX_URL must be reachable by the browser, not just Docker DNS.
CONVEX_SELF_HOSTED_URL=
CONVEX_SELF_HOSTED_ADMIN_KEY=
CONVEX_SELF_HOSTED_IMAGE_TAG=latest
CONVEX_CLOUD_ORIGIN=
CONVEX_SITE_ORIGIN=http://127.0.0.1:3211
CONVEX_BACKEND_BIND=127.0.0.1
CONVEX_BACKEND_PORT=3210
CONVEX_SITE_BIND=127.0.0.1
CONVEX_SITE_PORT=3211
CONVEX_DASHBOARD_BIND=127.0.0.1
CONVEX_DASHBOARD_PORT=6791
CONVEX_TRAEFIK_ENABLE=false
CONVEX_TRAEFIK_HOST=convex-events.ineedtofeedmyrabbit.com
ADMIN_CLERK_USER_IDS=
OPENAI_API_KEY=
APIFY_API_TOKEN=
APIFY_INSTAGRAM_ACTOR_ID=apify/instagram-post-scraper
APIFY_DATA_DETAIL_LEVEL=basicData
APIFY_MAX_TOTAL_CHARGE_USD_PER_RUN=0.02
APIFY_RUN_TIMEOUT_SECONDS=180
APIFY_MEMORY_MBYTES=4096
APIFY_SKIP_PINNED_POSTS=false
INGESTION_FULL_SCRAPE_CONCURRENCY=8
INGESTION_POST_STEP_LIMIT=8
SCRAPED_POST_PAGE_SIZE=25
INGESTION_REPROCESS_EXISTING_SOURCE_POSTS=false
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_REVIEW_MODEL=gpt-4.1-mini
CRON_SECRET=
CRON_RESULTS_LIMIT=1
CRON_DAYS_BACK=10
CRON_INGESTION_MAX_STEPS=20
CRON_INGESTION_BATCH_SIZE=64
CRON_MAX_HANDLES_PER_RUN=600
CRON_FULL_SCRAPE_COOLDOWN_HOURS=23
GOOGLE_MAPS_API_KEY=
VENUE_HOURS_GOOGLE_FALLBACK=false
FOLLOW_DISCOVERY_SOURCE_HANDLE=going_places11
FOLLOW_DISCOVERY_ACTOR_ID=scraping_solutions/instagram-scraper-followers-following-no-cookies
FOLLOW_DISCOVERY_RESULTS_LIMIT=700
FOLLOW_DISCOVERY_MAX_TOTAL_CHARGE_USD=0.5
FOLLOW_DISCOVERY_TIMEOUT_SECONDS=300
FOLLOW_DISCOVERY_INGESTION_RESULTS_LIMIT=1
FOLLOW_DISCOVERY_INGESTION_DAYS_BACK=10
