{
  "name": "ig_event",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "qa:dedupe": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/qa-deduplication.mjs",
    "qa:automerge": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/qa-approved-event-automerge.mjs",
    "qa:extraction": "node --import ./scripts/register-ts-paths.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/qa-extraction-standardization.mjs",
    "qa:moderation-queue": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/qa-moderation-queue.mjs",
    "qa:venue-types": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/qa-venue-type-taxonomy.mjs",
    "qa:venue-hours": "node --import ./scripts/register-ts-paths.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/qa-venue-hours.mjs",
    "qa:reclassify-dryrun": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/reclassify-event-types.mjs",
    "repair:event-consistency": "node --import ./scripts/register-ts-paths.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/repair-event-consistency.mjs",
    "qa:public-search": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/qa-public-event-search.mjs",
    "qa:public-sort": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/qa-public-event-sort.mjs",
    "qa:public-performance": "node scripts/qa-public-performance.mjs",
    "qa:mobile-calendar": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/qa-mobile-calendar-density.mjs",
    "qa:app-toolbar": "node scripts/qa-app-toolbar.mjs",
    "qa:apify": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/qa-apify-cost-controls.mjs",
    "qa:follow-discovery": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/qa-follow-discovery.mjs",
    "qa:convex-retention-cron": "node scripts/qa-convex-retention-cron.mjs",
    "qa:clerk-instagram-sso": "node scripts/qa-clerk-instagram-sso.mjs",
    "qa:release": "node scripts/release-check.mjs",
    "convex:codegen": "npx convex codegen --typecheck disable"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.37.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.31.7",
    "csv-parse": "^6.1.0",
    "lucide-react": "^0.564.0",
    "next": "^14.2.0",
    "opening_hours": "^3.13.0",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
