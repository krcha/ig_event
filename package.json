    "qa:admin-auth": "node scripts/qa-admin-auth.mjs",
    "qa:release": "node scripts/release-check.mjs",
    "qa:self-hosted-convex-compose": "docker compose --env-file .env.production.example -f docker-compose.yml -f docker-compose.self-hosted-convex.yml config --quiet",
