# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.node_modules-stale-build-timeout-*/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# root-level generated test output
/coverage/
/test-results/
/test-results */
/playwright-report/
/playwright-report */
/blob-report/
/blob-report */
/traces/
/screenshots/
/*.trace
/trace.zip

# next.js root output
/.next/
/.next */
/out/
/out */

# production root output
/build/
/build */

# scratch scripts and copy-style source duplicates
/scripts/tmp-*
/app/**/* [0-9]*.[jt]s
/app/**/* [0-9]*.[jt]sx
/components/**/* [0-9]*.[jt]s
/components/**/* [0-9]*.[jt]sx
/convex/**/* [0-9]*.[jt]s
/convex/**/* [0-9]*.[jt]sx
/lib/**/* [0-9]*.[jt]s
/lib/**/* [0-9]*.[jt]sx
/scripts/**/* [0-9]*.[cm][jt]s
/scripts/**/* [0-9]*.[jt]s
/scripts/**/* [0-9]*.[jt]sx

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
